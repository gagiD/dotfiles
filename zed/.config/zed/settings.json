// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": "Material Icon Theme",
  "theme": "Tokyo Night",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 22,
  "buffer_font_features": {
    "calt": true,
  },
  "ui_font_size": 20,
  "agent_ui_font_size": 18,
  "agent_buffer_font_size": 18,
  "relative_line_numbers": "enabled",
  // "cursor_shape": "block",

  "format_on_save": "on",
  "autosave": "on_focus_change",

  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "base_keymap": "VSCode",

  "minimap": {
    "show": false,
  },
  "show_whitespace": "trailing",

  "telemetry": {
    "metrics": true,
    "diagnostics": true,
  },

  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 16,
    "line_height": "comfortable",
  },

  "project_panel": {
    "dock": "right",
    "compact_folders": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },

  "languages": {
    "CSharp": {
      "language_servers": ["roslyn", "!omnisharp"],
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "file_types": {
    "JSON": ["JSONC"],
  },

  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^pnpm\\s+nx(\\s|$)",
            },
            {
              "pattern": "^npx\\s+nx(\\s|$)",
            },
            {
              "pattern": "^tail\\b",
            },
            {
              "pattern": "^npx\\s+jest(\\s|$)",
            },
            {
              "pattern": "^npm\\s+exec(\\s|$)",
            },
          ],
        },
        "fetch": {
          "default": "allow",
        },
      },
    },
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
}
